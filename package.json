{
  "name": "@subframe7536/eslint-config",
  "type": "module",
  "version": "0.4.3",
  "description": "self use eslint config, extends @antfu",
  "author": "subframe7536",
  "license": "MIT",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "release": "pnpm build && bumpp --all && npm publish"
  },
  "peerDependencies": {
    "eslint": "^8"
  },
  "dependencies": {
    "@antfu/eslint-config": "^2.0.0",
    "eslint-plugin-solid": "^0.13.0",
    "local-pkg": "^0.5.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@subframe7536/type-utils": "^0.1.4",
    "bumpp": "^9.2.0",
    "eslint": "^8.54.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  }
}
