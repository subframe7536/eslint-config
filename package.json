{
  "name": "@subframe7536/eslint-config",
  "type": "module",
  "version": "0.7.2",
  "description": "eslint config extends @antfu",
  "author": "subframe7536",
  "license": "MIT",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "release": "bun run build && bumpp --all && npm publish"
  },
  "peerDependencies": {
    "eslint": ">=8.40"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@antfu/eslint-config": "2.23.1"
  },
  "devDependencies": {
    "@subframe7536/type-utils": "^0.1.6",
    "bumpp": "^9.4.1",
    "eslint": "^9.7.0",
    "tsup": "8.1.0",
    "typescript": "^5.5.3"
  }
}
